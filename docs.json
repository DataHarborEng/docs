{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "DataHarbor",
  "description": "DataHarbor enables safe data reuse by publishing governed, purpose-limited data products from a single source of truth—built for an AI-driven world.",
  "colors": {
    "primary": "#0ea5e9",
    "light": "#06b6d4",
    "dark": "#0f172a"
  },
  "favicon": "/favicon.ico",
  "appearance": {
    "default": "light"
  },
  "styling": {
    "eyebrow": "breadcrumbs",
    "codeBlock": "dark"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "concepts"
            ]
          },
          {
            "group": "Core",
            "pages": [
              "core/virtual-apis",
              "core/enrolling-data-sources"
            ]
          },
          {
            "group": "Control Blocks",
            "pages": [
              "control-blocks/data-control",
              "control-blocks/data-transform",
              "control-blocks/access-control",
              "control-blocks/data-fusion"
            ]
          },
          {
            "group": "Delivery",
            "pages": [
              "delivery/rest-api",
              "delivery/mcp-server",
              "delivery/data-lake"
            ]
          },
          {
            "group": "Protect",
            "pages": [
              "protect/schema-analytics",
              "protect/data-remediation"
            ]
          },
          {
            "group": "Marketplace",
            "pages": [
              "marketplace/global",
              "marketplace/private"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Configuration",
            "pages": [
              "api-reference/yaml-reference",
              "api-reference/control-block-reference"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://dataharbor.co",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@dataharbor.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Join the Waitlist",
      "href": "https://dataharbor.co"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dataharboreng",
      "linkedin": "https://linkedin.com/company/dataharbor",
      "website": "https://dataharbor.co"
    }
  }
}
